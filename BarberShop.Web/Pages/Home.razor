@page "/"
@layout HeadlessLayout

<PageTitle>Essencia da Beleza | Home</PageTitle>

<main class="home-page @(_isDarkMode ? "home-page--dark" : "home-page--light")">
    <nav class="home-nav" aria-label="Navegacao principal">
        <a class="home-brand" href="/">
            <img src="Imgs/logo23-transparent.png" alt="Essencia da Beleza" />
        </a>

        <div class="home-nav__links">
            <NavLink href="/" Match="NavLinkMatch.All" class="home-nav__link">Inicio</NavLink>
            <NavLink href="/agendamentos" class="home-nav__link">Agendamentos</NavLink>
            <NavLink href="/cortes" class="home-nav__link">Cortes</NavLink>
            <NavLink href="/avaliacoes" class="home-nav__link">Avaliacoes</NavLink>
            <NavLink href="/perfil" class="home-nav__link">Perfil</NavLink>

            <AuthorizeView Roles="Admin">
                <Authorized Context="adminContext">
                    <details class="app-admin-menu">
                        <summary class="home-nav__link app-admin-menu__trigger">
                            Admin
                        </summary>

                        <div class="app-admin-menu__panel" role="menu" aria-label="Menu admin">
                            <span class="app-admin-menu__label">Admin</span>
                            <NavLink href="/admin/agendamentos" class="app-admin-menu__item" role="menuitem">
                                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                                <span>Gerenciar Agendamentos</span>
                            </NavLink>
                            <NavLink href="/admin/cortes" class="app-admin-menu__item" role="menuitem">
                                <MudIcon Icon="@Icons.Material.Filled.ContentCut" Size="Size.Small" />
                                <span>Servicos</span>
                            </NavLink>
                        </div>
                    </details>
                </Authorized>
            </AuthorizeView>

            <NavLink href="/sair" class="home-nav__link">Sair</NavLink>
        </div>

    </nav>

    <section class="home-hero" aria-labelledby="home-title">
        <div class="home-hero__content">
            <span class="home-pill">Bem-vindo</span>
            <h1 id="home-title">Estilo que acompanha o seu ritmo</h1>
            <p>
                Agende seu horario, escolha o corte ideal e viva uma experiencia de barbearia
                pensada para quem valoriza cuidado, presenca e acabamento.
            </p>

            <div class="home-actions">
                <a class="home-button home-button--primary" href="/agendamentos">Agende Agora</a>
                <a class="home-button home-button--ghost" href="/cortes">Explorar Cortes</a>
            </div>
        </div>

        <div class="home-hero__showcase" aria-label="Corte masculino em destaque">
            <div class="home-hero__image-frame">
                <img src="Imgs/corte-de-cabelo-social-2.png" alt="Cliente com corte masculino social" />
            </div>
            <div class="home-hero__floating-card">
                <span>Atendimento</span>
                <strong>com hora marcada</strong>
            </div>
        </div>
    </section>

    <section class="home-about" aria-labelledby="about-title">
        <div class="home-section-copy">
            <span class="home-section-pill">Historia rapida</span>
            <h2 id="about-title">Sobre a Essência da Beleza</h2>
            <p>
                A barbearia de Eromar Leite Silva está há mais de 20 anos atendendo clientes na cidade de Jucás-CE com dedicação, experiência e qualidade. Trabalhamos com cortes masculinos, femininos e infantis, oferecendo diversos estilos para valorizar o visual de cada cliente.

                Com tradição e confiança, buscamos proporcionar um atendimento simples, acolhedor e cuidadoso, sempre respeitando o gosto de cada pessoa e entregando um resultado feito com atenção aos detalhes. ou personalizado, nossa barbearia está pronta para receber você.
            </p>
            <p>
                Da agenda organizada ao corte final, nossa experiência foi pensada para ser simples,
                elegante e confiável.
            </p>
        </div>

        <div class="home-about__media">
            <img src="Imgs/lowfade.png" alt="Corte masculino com acabamento em degradê" />
        </div>
    </section>

    <section class="home-highlights" aria-labelledby="highlights-title">
        <div class="home-highlights__content">
            <span class="home-section-pill">Destaques</span>
            <h2 id="highlights-title">Nossos diferenciais</h2>

            <div class="home-highlight-grid">
                <div class="home-highlight-card">
                    <strong>Agenda simples</strong>
                    <span>Escolha o melhor horário sem complicação.</span>
                </div>
                <div class="home-highlight-card">
                    <strong>Cortes atuais</strong>
                    <span>Social, fade, americano, moicano e muito mais.</span>
                </div>
                <div class="home-highlight-card">
                    <strong>Atendimento pontual</strong>
                    <span>Horários organizados para você não perder tempo.</span>
                </div>
                <div class="home-highlight-card">
                    <strong>Acabamento premium</strong>
                    <span>Detalhes bem feitos para um resultado limpo.</span>
                </div>
            </div>
        </div>

        <div class="home-highlights__media">
            <img src="Imgs/americano.png" alt="Corte masculino americano" />
        </div>
    </section>

    <section class="home-info" aria-labelledby="info-title">
        <span class="home-section-pill">Informacoes importantes</span>
        <h2 id="info-title">Contato e funcionamento</h2>

        <div class="home-info-grid">
            <article class="home-info-card home-info-card--contact">
                <span>Contato</span>
                <h3>Fale com a gente</h3>
                <p>Tem alguma duvida ou quer confirmar um horário? Nossa equipe esta pronta para ajudar.</p>
                <a href="tel:+5588998056764">(88) 99805-6764</a>
                <a href="tel:+5588997289611">(88) 99728-9611</a>
                <a href="mailto:cleucysilva08@gmail.com">cleucysilva08@gmail.com</a>
            </article>

            <article class="home-info-card home-info-card--hours">
                <span>Horários</span>
                <h3>Dias abertos</h3>
                <dl>
                    <div>
                        <dt>Segunda a Sexta</dt>
                        <dd>07h as 19h</dd>
                    </div>
                    <div>
                        <dt>Sábado</dt>
                        <dd>07h as 12h</dd>
                    </div>
                    <div>
                        <dt>Domingo</dt>
                        <dd>Fechado</dd>
                    </div>
                </dl>
            </article>

            <article class="home-info-card home-info-card--visit">
                <span>Agendamento</span>
                <h3>Atendimento com hora marcada</h3>
                <p>Garanta seu horário e escolha o corte ideal para o seu momento.</p>
                <a class="home-info-button" href="/agendamentos">Agendar agora</a>
            </article>
        </div>
    </section>
</main>

@code {
    private bool _isDarkMode = true;
}
