@page "/"
@layout HeadlessLayout

<PageTitle>Essencia da Beleza | Home</PageTitle>

<main class="home-page @(_isDarkMode ? "home-page--dark" : "home-page--light")">
    <nav class="home-nav" aria-label="Navegacao principal">
        <a class="home-brand" href="/">
            <img src="Imgs/logo23-transparent.png" alt="Essencia da Beleza" />
        </a>

        <div class="home-nav__links">
            <NavLink href="/" Match="NavLinkMatch.All" class="home-nav__link">Inicio</NavLink>
            <NavLink href="/agendamentos" class="home-nav__link">Agendamentos</NavLink>
            <NavLink href="/cortes" class="home-nav__link">Cortes</NavLink>
            <NavLink href="/avaliacoes" class="home-nav__link">Avaliacoes</NavLink>
            <NavLink href="/perfil" class="home-nav__link">Perfil</NavLink>

            <AuthorizeView Roles="Admin">
                <Authorized Context="adminContext">
                    <details class="app-admin-menu">
                        <summary class="home-nav__link app-admin-menu__trigger">
                            Admin
                        </summary>

                        <div class="app-admin-menu__panel" role="menu" aria-label="Menu admin">
                            <span class="app-admin-menu__label">Admin</span>
                            <NavLink href="/admin/agendamentos" class="app-admin-menu__item" role="menuitem">
                                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                                <span>Gerenciar Agendamentos</span>
                            </NavLink>
                            <NavLink href="/admin/cortes" class="app-admin-menu__item" role="menuitem">
                                <MudIcon Icon="@Icons.Material.Filled.ContentCut" Size="Size.Small" />
                                <span>Servicos</span>
                            </NavLink>
                        </div>
                    </details>
                </Authorized>
            </AuthorizeView>

            <NavLink href="/sair" class="home-nav__link">Sair</NavLink>
        </div>

    </nav>

    <section class="home-hero" aria-labelledby="home-title">
        <div class="home-hero__content">
            <span class="home-pill">Bem-vindo</span>
            <h1 id="home-title">Estilo que acompanha o seu ritmo</h1>
            <p>
                Agende seu horario, escolha o corte ideal e viva uma experiencia de barbearia
                pensada para quem valoriza cuidado, presenca e acabamento.
            </p>

            <div class="home-actions">
                <a class="home-button home-button--primary" href="/agendamentos">Agende Agora</a>
                <a class="home-button home-button--ghost" href="/cortes">Explorar Cortes</a>
            </div>
        </div>

        <div class="home-hero__showcase" aria-label="Corte masculino em destaque">
            <div class="home-hero__image-frame">
                <img src="Imgs/corte-de-cabelo-social-2.png" alt="Cliente com corte masculino social" />
            </div>
            <div class="home-hero__floating-card">
                <span>Atendimento</span>
                <strong>com hora marcada</strong>
            </div>
        </div>
    </section>

    <section class="home-strip" aria-label="Destaques da barbearia">
        <a href="/agendamentos" class="home-strip__item">
            <span>01</span>
            <strong>Agenda simples</strong>
        </a>
        <a href="/cortes" class="home-strip__item">
            <span>02</span>
            <strong>Cortes em destaque</strong>
        </a>
        <a href="/avaliacoes" class="home-strip__item">
            <span>03</span>
            <strong>Opinioes reais</strong>
        </a>
    </section>
</main>

@code {
    private bool _isDarkMode = true;
}
