@page "/avaliacoes"
@inherits IndexAvaliacaoPage

<MudText Typo="Typo.h3" Class="mb-4">Minhas Avaliações</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Abaixo aparecem os serviços realizados hoje que você ainda não avaliou.
</MudAlert>

@if (IsBusy)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (AgendamentosParaAvaliar == null || !AgendamentosParaAvaliar.Any())
{
    <MudText>Nenhum serviço concluído hoje para avaliar.</MudText>
}
else
{
    <MudGrid>
        @foreach (var item in AgendamentosParaAvaliar)
        {
            <MudItem xs="12" md="6">
                <MudCard Elevation="3">
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Corte: @item.CorteId</MudText>
                        <MudText Typo="Typo.body2">Horário: @item.Data.ToString("HH:mm")</MudText>
                        <MudText Color="Color.Success"><b>Status: @item.Status</b></MudText>
                    </MudCardContent>

                    <MudCardActions>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Href="@($"/avaliacoes/adicionar/{item.Id}")">
                            Avaliar Agora
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}