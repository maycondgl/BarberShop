@page "/avaliacoes"
@inherits ListAvaliacaoPage

<MudText Typo="Typo.h3">Avaliações</MudText>

<MudDataGrid Items="@Agendamentos" Class="mt-4">
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="#" />
        <PropertyColumn Property="x => x.Corte.Titulo" Title="Corte" />
        <PropertyColumn Property="x => x.Data" Title="Data" />
        <TemplateColumn Title="Valor">
            <CellTemplate>
                @context.Item.Valor.ToString("C2", CultureInfo.GetCultureInfo("pt-BR"))
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Avaliação">
            <CellTemplate>
                @if (AgendamentosAvaliados.Contains(context.Item.Id))
                {
                    <MudChip Color="Color.Success" Size="Size.Small">Avaliado</MudChip>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/avaliacoes/adicionar/{context.Item.Id}")">
                        Avaliar
                    </MudButton>
                }
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>