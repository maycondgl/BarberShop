@page "/cortes"
@inherits ListCortesPage

<PageTitle>Cortes</PageTitle>

<div style="max-width: 1280px; margin: 0 auto; padding: 12px 0 56px;">
    <MudPaper Elevation="0"
              Class="pa-8 mb-6"
              Style="border-radius: 30px; border: 1px solid rgba(255,193,7,.18); background: radial-gradient(circle at 8% 0%, rgba(255,193,7,.20), transparent 34%), linear-gradient(135deg, #232326 0%, #141415 58%, #0d0d0e 100%); box-shadow: 0 26px 70px rgba(0,0,0,.35);">
        <div style="display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 28px; align-items: stretch;">
            <div>
                <MudText Typo="Typo.overline" Style="color: #ffc107; letter-spacing: .18em; font-weight: 800;">
                    Catálogo de cortes
                </MudText>
                <MudText Typo="Typo.h2" Style="font-weight: 800; line-height: 1; margin-top: 8px;">
                    Cortes
                </MudText>
                <MudText Typo="Typo.h5" Style="color: #ffc107; font-weight: 700; margin-top: 10px;">
                    Escolha seu estilo
                </MudText>
                <MudText Typo="Typo.body1" Style="max-width: 660px; color: rgba(255,255,255,.72); margin-top: 8px;">
                    Veja referencias de cortes, compare valores e escolha o visual ideal antes de agendar.
                </MudText>
            </div>

            <div style="border-radius: 26px; border: 1px solid rgba(255,193,7,.28); background: rgba(255,193,7,.08); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; min-height: 160px; color: #ffc107; text-align: center;">
                <MudIcon Icon="@Icons.Material.Filled.ContentCut" Size="Size.Large" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 800;">@Cortes.Count estilos disponiveis</MudText>
                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,.62);">Catalogo visual</MudText>
            </div>
        </div>
    </MudPaper>

    @if (IsBusy)
    {
        <MudGrid Spacing="4">
            @for (var i = 0; i < 6; i++)
            {
                <MudItem xs="12" sm="6" lg="4">
                    <MudSkeleton Height="380px" Style="border-radius: 28px;" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (!Cortes.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-6">
            Nenhum corte encontrado. Cadastre os cortes na API para montar o catalogo.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">
            @foreach (var corte in Catalogo)
            {

                <MudItem xs="12" sm="6" lg="4">
                    <MudCard Elevation="0"
                             SStyle="height: 100%; overflow: hidden; border-radius: 28px; border: 1px solid rgba(255,255,255,.08); background: linear-gradient(180deg, #242427, #181819); box-shadow: 0 20px 46px rgba(0,0,0,.30); transition: .18s ease;">
                        <div style="@corte.MediaStyle">
                            <MudImage Src="Imgs/corte-de-cabelo-social-2.png"
                                      Style="width: 100%; height: 210px; object-fit: cover;" />

                        </div>


                        <MudCardContent Style="padding: 22px;">
                            <MudText Typo="Typo.h5" Style="font-weight: 800;">@corte.Titulo</MudText>
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,.62); margin-top: 6px;">
                                Referencia visual para o cliente conhecer o resultado antes de marcar horario.
                            </MudText>

                            <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px;">
                                <MudChip Size="Size.Small" Style="background: rgba(255,255,255,.10); color: rgba(255,255,255,.84);">
                                    @FormatDuration(corte.DuracaoMinutos)
                                </MudChip>
                                <MudChip Size="Size.Small" Style="background: rgba(255,193,7,.16); color: #ffc107;">
                                    @FormatPrice(corte.Preco)
                                </MudChip>
                            </div>
                        </MudCardContent>

                        <MudCardActions Style="padding: 0 22px 22px; gap: 10px;">

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Event"
                                       OnClick="@(() => ScheduleCut(corte.Id))">
                                Agendar corte
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <MudPaper Elevation="0"
                  Class="pa-6 mt-6"
                  Style="border-radius: 30px; border: 1px solid rgba(255,255,255,.08); background: #1d1d1f; box-shadow: 0 22px 54px rgba(0,0,0,.24);">
            <MudText Typo="Typo.overline" Style="color: #ffc107; letter-spacing: .18em; font-weight: 800;">
                Valores
            </MudText>
            <MudText Typo="Typo.h4" Style="font-weight: 800; margin-bottom: 18px;">Tabela de Precos</MudText>

            <MudTable Items="@Catalogo" Hover="true" Style="overflow: hidden; border-radius: 20px; background: #181819;">
                <HeaderContent>
                    <MudTh>Corte</MudTh>
                    <MudTh>Duracao</MudTh>
                    <MudTh>Valor</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Corte">@context.Titulo</MudTd>
                    <MudTd DataLabel="Duracao">@FormatDuration(context.DuracaoMinutos)</MudTd>
                    <MudTd DataLabel="Valor">@FormatPrice(context.Preco)</MudTd>
                    <MudTd DataLabel="Agendar">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   OnClick="@(() => ScheduleCut(context.Id))">
                            Agendar
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</div>
