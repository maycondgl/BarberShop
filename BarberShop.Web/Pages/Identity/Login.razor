@page "/entrar"
@layout HeadlessLayout
@inherits LoginPage

<PageTitle>BarberShop - Entrar</PageTitle>

<main class="auth-page">
    <section class="auth-shell auth-shell--login" aria-label="Login">
        <div class="auth-panel auth-panel--form">
            <img class="auth-logo" src="Imgs/logo23-transparent.png" alt="Essencia da Beleza" />

            <div class="auth-heading">
                <h1>Entrar</h1>
                <p>Acesse sua conta para gerenciar seus agendamentos.</p>
            </div>

            <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync" class="auth-form">
                <DataAnnotationsValidator />

                <MudTextField T="string"
                              Label="E-mail"
                              For="@(() => InputModel.Email)"
                              @bind-Value="InputModel.Email"
                              InputType="InputType.Email"
                              Required="true"
                              RequiredError="E-mail inválido"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                <MudTextField T="string"
                              Label="Senha"
                              For="@(() => InputModel.Senha)"
                              @bind-Value="InputModel.Senha"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="Senha inválida"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                @if (IsBusy)
                {
                    <MudProgressCircular Color="Color.Warning" Indeterminate="true" />
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               Class="auth-submit">
                        Entrar
                    </MudButton>
                }
            </EditForm>
        </div>

        <aside class="auth-panel auth-panel--accent">
            <div>
                <span class="auth-kicker">Novo por aqui?</span>
                <h2>Crie sua conta</h2>
                <p>Cadastre-se para agendar cortes, acompanhar horários e viver a experiência Essencia da Beleza.</p>
            </div>

            <a class="auth-outline-button" href="/comecar">Quero me cadastrar</a>
        </aside>
    </section>
</main>
