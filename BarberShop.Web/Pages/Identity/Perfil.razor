@page "/perfil"
@using BarberShop.Web.Handlers
@using BarberShop.Core.Requests.Account
@inject AccountHandler AccountHandler
@inject ISnackbar Snackbar

<MudPaper Class="pa-6" Elevation="2" Style="max-width:500px; margin:auto;">
    <MudText Typo="Typo.h5" Class="mb-4">Meu Perfil</MudText>

    <EditForm Model="@Model" OnValidSubmit="SalvarAsync">
        <DataAnnotationsValidator />

        <MudTextField T="string"
                      Label="Nome Completo"
                      For="@(() => Model.Nome)"
                      @bind-Value="Model.Nome"
                      Required="true"
                      RequiredError="Nome obrigatório" />

        <MudTextField T="string"
                      Label="Telefone"
                      For="@(() => Model.Telefone)"
                      @bind-Value="Model.Telefone"
                      Required="true"
                      RequiredError="Telefone obrigatório" />

        <MudTextField T="string"
                      Label="E-mail"
                      For="@(() => Model.Email)"
                      @bind-Value="Model.Email"
                      Required="true"
                      RequiredError="E-mail obrigatório" />

        <MudStack Row="true" Spacing="2" Class="mt-6">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@IsBusy">
                Salvar
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Disabled="@IsBusy"
                       OnClick="ExcluirContaAsync">
                Excluir Conta
            </MudButton>
        </MudStack>
    </EditForm>
</MudPaper>

@code {

    private bool IsBusy = false;

    private UpdateProfileRequest Model { get; set; } = new();

    private async Task SalvarAsync()
    {
        IsBusy = true;

        var result = await AccountHandler.UpdateProfileAsync(Model);

        if (result.IsSuccess)
            Snackbar.Add("Perfil atualizado com sucesso!", Severity.Success);
        else
            Snackbar.Add(result.Message ?? "Erro ao atualizar perfil", Severity.Error);

        IsBusy = false;
    }

    private async Task ExcluirContaAsync()
    {
        IsBusy = true;

        var result = await AccountHandler.DeleteProfileAsync();

        if (result.IsSuccess)
            Snackbar.Add("Conta excluída com sucesso!", Severity.Success);
        else
            Snackbar.Add(result.Message ?? "Erro ao excluir conta", Severity.Error);

        IsBusy = false;
    }
}
