@page "/comecar"
@layout HeadlessLayout
@inherits RegisterPage

<PageTitle>BarberShop - Criar conta</PageTitle>

<main class="auth-page">
    <section class="auth-shell auth-shell--register" aria-label="Cadastro">
        <aside class="auth-panel auth-panel--accent">
            <div>
                <span class="auth-kicker">Bem-vindo</span>
                <h2>Já tem uma conta?</h2>
                <p>Entre para acessar seus agendamentos e continuar cuidando do seu estilo.</p>
            </div>

            <a class="auth-outline-button" href="/entrar">Fazer login</a>
        </aside>

        <div class="auth-panel auth-panel--form">
            <img class="auth-logo" src="Imgs/logo23-transparent.png" alt="Essencia da Beleza" />

            <div class="auth-heading">
                <h1>Criar conta</h1>
                <p>Preencha seus dados para começar a agendar.</p>
            </div>

            <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync" class="auth-form">
                <DataAnnotationsValidator />

                <MudTextField T="string"
                              Label="Nome completo"
                              For="@(() => InputModel.Nome)"
                              @bind-Value="InputModel.Nome"
                              Required="true"
                              RequiredError="Nome inválido"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                <MudTextField T="string"
                              Label="Número"
                              For="@(() => InputModel.Telefone)"
                              @bind-Value="InputModel.Telefone"
                              InputType="InputType.Telephone"
                              Required="true"
                              RequiredError="Número inválido"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                <MudTextField T="string"
                              Label="E-mail"
                              For="@(() => InputModel.Email)"
                              @bind-Value="InputModel.Email"
                              InputType="InputType.Email"
                              Required="true"
                              RequiredError="E-mail inválido"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                <MudTextField T="string"
                              Label="Senha"
                              For="@(() => InputModel.Senha)"
                              @bind-Value="InputModel.Senha"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="Senha inválida"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Class="auth-field" />

                @if (IsBusy)
                {
                    <MudProgressCircular Color="Color.Warning" Indeterminate="true" />
                }
                else
                {
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Warning"
                               Class="auth-submit">
                        Começar
                    </MudButton>
                }
            </EditForm>
        </div>
    </section>
</main>
